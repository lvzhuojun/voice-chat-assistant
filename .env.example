# ─────────────────────────────────────────────
# 服务地址
# ─────────────────────────────────────────────
HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ─────────────────────────────────────────────
# 数据库 & 缓存
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/voicechat
REDIS_URL=redis://localhost:6379
# 生产环境 Docker 部署时 Redis 需设置密码：
# REDIS_URL=redis://:your_redis_password@localhost:6379
POSTGRES_PASSWORD=voicechat_dev_password
REDIS_PASSWORD=

# ─────────────────────────────────────────────
# JWT 认证
# 强烈建议生成强随机密钥：
#   python -c "import secrets; print(secrets.token_hex(32))"
# ─────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-random-string
JWT_EXPIRE_DAYS=7

# ─────────────────────────────────────────────
# LLM（OpenAI 兼容接口）
# Key 为空时自动使用 mock 回复，不崩溃
# ─────────────────────────────────────────────
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────
# STT (faster-whisper)
# ─────────────────────────────────────────────
WHISPER_MODEL_SIZE=medium
WHISPER_DEVICE=cuda

# ─────────────────────────────────────────────
# TTS (GPT-SoVITS，对接项目一)
# ─────────────────────────────────────────────
GPTSOVITS_DIR=./GPT_SoVITS
VOICE_MODELS_DIR=./storage/voice_models
PRETRAINED_MODELS_DIR=./storage/pretrained_models/GPT_SoVITS
STORAGE_DIR=./storage

# ─────────────────────────────────────────────
# TTS (CosyVoice 2，可选)
# 不使用 CosyVoice 2 引擎时可留空或省略此项
# 预训练模型需位于 {COSYVOICE_DIR}/pretrained_models/CosyVoice2-0.5B
# ─────────────────────────────────────────────
COSYVOICE_DIR=./CosyVoice

# ─────────────────────────────────────────────
# 安全与限制
# ─────────────────────────────────────────────
# 生产部署时追加额外的 CORS 允许来源（逗号分隔）
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=

# 音色 ZIP 包最大上传大小（MB），默认 500
MAX_UPLOAD_SIZE_MB=500
