# ─────────────────────────────────────────────
# 服务地址
# ─────────────────────────────────────────────
HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ─────────────────────────────────────────────
# 数据库 & 缓存
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/voicechat
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# JWT 认证
# ─────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-random-string
JWT_EXPIRE_DAYS=7

# ─────────────────────────────────────────────
# LLM（OpenAI 兼容接口）
# Key 为空时自动使用 mock 回复，不崩溃
# ─────────────────────────────────────────────
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────
# STT (faster-whisper)
# ─────────────────────────────────────────────
WHISPER_MODEL_SIZE=medium
WHISPER_DEVICE=cuda

# ─────────────────────────────────────────────
# TTS (GPT-SoVITS，对接项目一)
# ─────────────────────────────────────────────
GPTSOVITS_DIR=./GPT-SoVITS
VOICE_MODELS_DIR=./storage/voice_models
PRETRAINED_MODELS_DIR=./storage/pretrained_models/GPT-SoVITS
STORAGE_DIR=./storage
